@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Error — ITI Exams</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; background: #f4f6f9; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .error-card { background: white; border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.08); padding: 60px 50px; text-align: center; max-width: 500px; }
        .error-icon { font-size: 4rem; color: #dc3545; margin-bottom: 20px; }
    </style>
</head>
<body>
    <div class="error-card">
        <div class="error-icon"><i class="fas fa-exclamation-triangle"></i></div>
        <h2 class="fw-bold text-dark mb-2">Something went wrong</h2>
        <p class="text-muted mb-4">An unexpected error occurred. Please try again or contact support.</p>
        @if (Model.ShowRequestId)
        {
            <p class="text-muted small">Request ID: <code>@Model.RequestId</code></p>
        }
        <a href="/" class="btn btn-primary rounded-pill px-4">Go Home</a>
    </div>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
</body>
</html>
