<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — ITI Exams" : "ITI Examination System")</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Font Awesome 6 -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- ── Sidebar Navigation ── -->
    <nav id="sidebar" class="sidebar d-flex flex-column">
        <div class="sidebar-brand">
            <div class="brand-icon">
                <i class="fas fa-graduation-cap"></i>
            </div>
            <div>
                <div class="brand-name">ITI Exams</div>
                <div class="brand-subtitle">Examination System</div>
            </div>
        </div>

        <hr class="sidebar-divider" />

        <ul class="sidebar-nav">
            <li class="nav-item">
                <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Student" ? "active" : "")"
                   asp-controller="Student" asp-action="Index">
                    <i class="fas fa-home"></i>
                    <span>Dashboard</span>
                </a>
            </li>
        </ul>

        <div class="sidebar-footer mt-auto">
            <div class="student-info">
                <div class="student-avatar">
                    <i class="fas fa-user-graduate"></i>
                </div>
                <div class="student-details">
                    <div class="student-name">@(ViewBag.StudentName ?? HttpContext.Session.GetString("StudentName") ?? "Student")</div>
                    <div class="student-role">Student</div>
                </div>
            </div>
            <a asp-controller="Account" asp-action="Logout" class="logout-btn">
                <i class="fas fa-sign-out-alt me-2"></i> Logout
            </a>
        </div>
    </nav>

    <!-- ── Main Content ── -->
    <div id="main-content" class="main-content">
        <!-- Top bar with mobile toggle -->
        <div class="topbar d-flex align-items-center d-lg-none">
            <button class="btn btn-link sidebar-toggle me-3" id="sidebarToggle">
                <i class="fas fa-bars fa-lg text-dark"></i>
            </button>
            <span class="fw-bold text-dark">ITI Exams</span>
        </div>

        <!-- Toast notifications -->
        @if (TempData["Warning"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show mx-4 mt-3" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Warning"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mx-4 mt-3" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <main class="page-content">
            @RenderBody()
        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Site JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
